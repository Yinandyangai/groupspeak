# ─── Shared secrets ────────────────────────────────────────────────
# Use a real 64-char random string in prod: openssl rand -hex 32
JWT_SECRET=dev-only-secret-change-me-please-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# ─── Postgres ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://groupspeak:groupspeak@localhost:5432/groupspeak?schema=public

# ─── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Realtime server ───────────────────────────────────────────────
REALTIME_PORT=4000
REALTIME_PUBLIC_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# ─── Anthropic (AI augmentation layer) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# ─── Web (Next.js) ─────────────────────────────────────────────────
NEXT_PUBLIC_REALTIME_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── WebRTC ICE servers ────────────────────────────────────────────
# JSON array string parsed at runtime. STUN is enough for most NATs.
# In production, add a TURN server (coturn or Twilio NTS) for symmetric-NAT users.
NEXT_PUBLIC_ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302","stun:stun1.l.google.com:19302"]}]

# Example with TURN:
# NEXT_PUBLIC_ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:turn.example.com:3478"],"username":"groupspeak","credential":"changeme"}]
